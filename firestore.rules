rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Cover every subcollection under /users/{userId} (profile, files, notes,
      // links, activity, vault/**, security/**, etc.) without enumerating each
      // one explicitly.
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
